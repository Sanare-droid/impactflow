# =============================================================================
# ImpactFlow AI — Environment Configuration
# Copy to .env and fill in values. Never commit .env.
# =============================================================================

# --- Application ---
APP_NAME=ImpactFlow AI
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
FRONTEND_URL=http://localhost:3000
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# --- Database (PostgreSQL + PostGIS) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=impactflow
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=impactflow
DATABASE_URL=postgresql+asyncpg://impactflow:change_me_strong_password@localhost:5432/impactflow

# --- Redis (sessions / rate limiting / token blacklist) ---
REDIS_URL=redis://localhost:6379/0

# --- Auth / JWT ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=replace_with_long_random_secret_at_least_64_characters_long_please
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
MFA_ISSUER=ImpactFlow AI

# --- Encryption (Fernet key for MFA secrets at rest) ---
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace_with_fernet_key_from_cryptography_Fernet_generate_key

# --- Object Storage (S3-compatible) ---
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=impactflow
S3_SECRET_KEY=change_me_minio_secret
S3_BUCKET=impactflow
S3_REGION=us-east-1

# --- OpenAI (Phase 7; required later) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Email (Resend preferred, or SMTP) ---
RESEND_API_KEY=
# Verified sender, e.g. ImpactFlow <noreply@yourdomain.com>
# Until domain is verified on Resend you can use: ImpactFlow <onboarding@resend.dev>
SMTP_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true

JOBS_POLL_SECONDS=30
JOBS_ENABLED=true

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=ImpactFlow AI
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Optional platform superadmin (created/updated on API startup) ---
# SUPERADMIN_EMAIL=admin@yourdomain.com
# SUPERADMIN_PASSWORD=ChangeMeStrong123!
# SUPERADMIN_FIRST_NAME=Platform
# SUPERADMIN_LAST_NAME=Admin

# Allow Netlify origins automatically (API). Also set BACKEND_CORS_ORIGINS to your exact site.
# BACKEND_CORS_ORIGIN_REGEX=https://.*\.netlify\.app
