{
  "expo": {
    "name": "ImpactFlow Field",
    "slug": "impactflow-field",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "impactflow",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.impactflow.field"
    },
    "android": {
      "package": "ai.impactflow.field",
      "adaptiveIcon": {
        "backgroundColor": "#0F766E"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-sqlite",
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "ImpactFlow Field uses your location to geotag field registrations."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "ImpactFlow Field accesses photos to attach evidence to field records."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
