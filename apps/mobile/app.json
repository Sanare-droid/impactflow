{
  "expo": {
    "name": "ImpactFlow Field",
    "slug": "impactflow-field",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "impactflow",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F766E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.impactflow.field"
    },
    "android": {
      "package": "ai.impactflow.field",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F766E"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-sqlite",
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "ImpactFlow Field uses your location to geotag field registrations."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "ImpactFlow Field accesses photos to attach evidence to field records."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "ecfeaaa0-c96d-42d6-8bfb-4258e706c100"
      },
      "router": {}
    },
    "owner": "sanaredroid"
  }
}
